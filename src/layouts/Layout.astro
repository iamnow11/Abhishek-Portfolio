---
import './Layout.css';
import NavBar from "../components/NavBar/NavBar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Abhishek Shah | Senior Frontend Engineer",
  description = "Abhishek Shah is a Senior Frontend Engineer specializing in Angular (v16–19), React 18, TypeScript, NgRx, and enterprise-grade scalable web applications.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Abhishek Shah" />
    <meta
      name="keywords"
      content="Abhishek Shah, Senior Frontend Engineer, Angular, React, NgRx, UX architecture"
    />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="AarusPortfolio" />
    <meta property="og:locale" content="en_US" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:creator" content="@iamnow11" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Abhishek Shah",
        url: "https://github.com/iamnow11",
        sameAs: [
          "https://github.com/iamnow11",
          "https://www.linkedin.com/in/iamnow/",
        ],
        jobTitle: "Senior Frontend Engineer",
        description: description,
        knowsAbout: [
          "Angular",
          "React",
          "TypeScript",
          "NgRx",
          "Redux",
          "Frontend Architecture",
          "Performance Optimization",
          "Enterprise Systems",
        ],
      })}
    />
    <link
      rel="preload"
      href="/fonts/SpaceGrotesk.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:global>
      @import "../styles/styles.css";
    </style>
  </head>
  <body>
    <div class="reading-progress" id="reading-progress"></div>
    <NavBar />

    <slot />

    <footer class="footer fade-in">
      <div class="footer-inner">
        <span class="footer-left">&copy; 2026 Abhishek Shah</span>
        <!-- <span class="footer-right">Built with Astro</span> -->
      </div>
    </footer>

    <script>
      import "./Layout.ts";
    </script>
  </body>
</html>
