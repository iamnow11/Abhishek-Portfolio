const featuredProjects = [
  {
    data: {
      title: "Enterprise Healthcare Coding Platform",
      description: "Scalable Angular-based system handling large healthcare datasets with optimized NgRx state management and performance tuning.",
      tech: ["Angular", "TypeScript", "NgRx", "SCSS"],
      github: "",
      live: "",
      stars: 0,
      featured: true,
    }
  },
  {
    data: {
      title: "Dynamic Configuration-Driven Platform",
      description: "Built modular UI systems driven by runtime configuration to support complex enterprise workflows.",
      tech: ["React", "TypeScript", "REST APIs"],
      github: "",
      live: "",
      stars: 0,
      featured: true,
    }
  }
];
const skillGroups = [
  {
    label: "Core Technologies",
    items: ["Angular (v16–19)", "React 18", "TypeScript", "JavaScript (ES6+)", "HTML5", "CSS3", "SCSS"],
  },
  {
    label: "State Management",
    items: ["NgRx", "Redux"],
  },
  {
    label: "Backend & APIs",
    items: ["Node.js", "Express", "RESTful APIs"],
  },
  {
    label: "Performance & Architecture",
    items: ["Lazy Loading", "Code Splitting", "Virtual Scroll", "Change Detection Optimization", "Reusable Component Architecture"],
  },
  {
    label: "DevOps & Tools",
    items: ["Git", "GitHub", "Jenkins", "CI/CD", "Chrome DevTools", "Lighthouse"],
  },
];

const competencyHighlights = [
  {
    metric: "NgRx | Redux",
    description: "Reduced redundant API calls using NgRx caching strategy.",
  },
  {
    metric: "Performance",
    description: "Improved application load time using lazy loading and code splitting.",
  },
  {
    metric: "UI",
    description: "Built reusable UI component systems across enterprise modules.",
  },
  {
    metric: "Scale",
    description: "Designed scalable configuration-driven architecture.",
  },
  {
    metric: "CI/CD",
    description: "Contributed to CI/CD pipeline optimization using Jenkins.",
  },
  {
    metric: "Stability",
    description: "Delivered optimized and stable modules across enterprise systems.",
  },
];

const workExperience = [
  {
    company: "AGS Health",
    duration: "Apr 2025 – Present",
    role: "Frontend Engineer",
    responsibilities: [
      "Developed scalable Angular (v16–19) and React modules for enterprise healthcare platforms.",
      "Implemented NgRx-based state management to reduce redundant API calls.",
      "Built reusable component architecture.",
      "Applied lazy loading and dynamic imports.",
      "Integrated secure REST APIs.",
      "Contributed to CI/CD pipelines.",
      "Collaborated in Agile environment."
    ]
  },
  {
    company: "Tata Consultancy Services",
    duration: "Jun 2021 – Apr 2025",
    role: "Frontend Developer",
    responsibilities: [
      "Developed dynamic configuration-driven modules.",
      "Built modular UI systems following enterprise standards.",
      "Optimized performance and stability.",
      "Worked with React, TypeScript, REST APIs.",
      "Contributed to CI/CD automation."
    ]
  }
];
---

<Layout>
  <HeroSection />

  <main>
    <section id="about" class="section fade-in">
      <div class="container">
        <SectionHeader title="about" number="01" />
        <div class="about-content">
          <p>
            I am a Frontend Engineer with over 4 years of experience designing and developing enterprise-scale healthcare audit and coding platforms. I specialize in Angular and React ecosystems, with strong expertise in state management using NgRx and Redux. My work focuses on performance optimization, scalable architecture, reusable component systems, and complex UI workflows in large applications.
          </p>
          <p>
            Currently working on enterprise healthcare systems where I build dynamic modules, optimize API integrations, and improve application performance across large datasets.
          </p>
        </div>
      </div>
    </section>

    <section id="highlights" class="section fade-in">
      <div class="container">
        <SectionHeader title="highlights" number="02" />
        <div class="highlights-wrapper">
          <div class="highlights-grid">
            {
              competencyHighlights.map((highlight, index) => (
                <div class="highlight-card slide-up" style={`animation-delay: ${index * 0.1}s`}>
                  <span class="highlight-metric">{highlight.metric}</span>
                  <span class="highlight-label">{highlight.description}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="section fade-in">
      <div class="container">
        <SectionHeader title="featured work" number="03" />
        <div class="flagship-grid">
          {
            featuredProjects.map((project, index) => (
              <FeaturedProject
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                github={project.data.github}
                live={project.data.live}
                stars={project.data.stars}
                index={index}
              />
            ))
          }
        </div>

        <h3 class="subsection-title">All Projects</h3>
        <div class="projects-grid">
          <!-- {
            allProjects.map((project, index) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                github={project.data.github}
                live={project.data.live}
                stars={project.data.stars}
                index={index}
              />
            ))
          } -->
        </div>
      </div>
    </section>

    <section id="skills" class="section fade-in">
      <div class="container">
        <SectionHeader title="tech stack" number="04" />
        <div class="skills-grouped">
          {
            skillGroups.map((group, groupIndex) => (
              <div class="skill-group slide-up" style={`animation-delay: ${groupIndex * 0.1}s`}>
                <span class="skill-group-label">{group.label}</span>
                <div class="skill-group-items">
                  {group.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="building" class="section fade-in">
      <div class="container">
        <SectionHeader title="experience" number="05" />
        <div class="building-list">
          {
            workExperience.map((experience, index) => (
              <div class="building-item slide-up" style={`animation-delay: ${index * 0.1}s`}>
                <div class="building-header">
                  <span class="building-name">{experience.company}</span>
                  <span class="building-duration">{experience.duration}</span>
                </div>
                <div class="building-role">{experience.role}</div>
                <ul class="building-bullets">
                  {experience.responsibilities.map((responsibility) => (
                    <li>{responsibility}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="contact" class="section fade-in">
      <div class="container">
        <SectionHeader title="contact" number="06" />
        <ContactForm />
      </div>
    </section>
  </main>
</Layout>
